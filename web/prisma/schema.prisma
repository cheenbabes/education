generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth (NextAuth) ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- App Models ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  state         String?   // US state abbreviation for standards

  accounts       Account[]
  sessions       Session[]
  children       Child[]
  lessons        Lesson[]
  compassResults CompassResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Child {
  id             String  @id @default(cuid())
  userId         String
  name           String
  dateOfBirth    DateTime
  gradeLevel     String  // K, 1, 2, ... 12
  standardsOptIn Boolean @default(true)

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonChildren   LessonChild[]
  lessonObjectives LessonObjective[]
  completions      Completion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lesson {
  id                     String   @id @default(cuid())
  userId                 String
  title                  String
  interest               String
  philosophy             String   // adaptive, waldorf-adjacent, montessori-inspired, project-based, place-nature-based
  subjects               String[] // standards codes (e.g. CCSS.Math.Content.4.OA.A.2)
  subjectNames           String[] @default([]) // human-readable (e.g. Math, Language Arts)
  multiSubjectOptimized  Boolean  @default(false)
  content                Json     // full lesson plan JSON
  contentHash            String   // for dedup detection
  favorite               Boolean  @default(false)

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonChildren   LessonChild[]
  lessonObjectives LessonObjective[]
  completions      Completion[]
  calendarEntries  CalendarEntry[]

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([contentHash])
}

model LessonChild {
  id       String @id @default(cuid())
  lessonId String
  childId  String

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  child  Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([lessonId, childId])
}

model LessonObjective {
  id               String @id @default(cuid())
  lessonId         String
  childId          String
  standardCode     String // references KG standard code
  subject          String
  descriptionPlain String // parent-friendly description

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  child  Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId, subject])
  @@index([childId, standardCode])
}

model Completion {
  id         String   @id @default(cuid())
  lessonId   String
  childId    String
  starRating Int      // 1-5
  notes      String?  @db.Text

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  child  Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  completedAt DateTime @default(now())

  @@unique([lessonId, childId])
}

model CalendarEntry {
  id            String   @id @default(cuid())
  lessonId      String
  userId        String
  scheduledDate DateTime @db.Date

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId, scheduledDate])
}

// --- Education Compass ---

model CompassResult {
  id               String   @id @default(uuid())
  email            String
  archetype        String
  dimensionScores  Json     // {structure: 72, modality: 35, ...}
  philosophyBlend  Json     // {montessori: 0.45, waldorf: 0.20, ...}
  part2Preferences Json     // {subjects, prep_level, budget, ...}
  accountId        String?

  account          User?    @relation(fields: [accountId], references: [id], onDelete: SetNull)
  curriculumPicks  CompassCurriculumPick[]

  createdAt DateTime @default(now())

  @@index([email])
  @@index([accountId])
}

model Curriculum {
  id               String   @id @default(uuid())
  name             String
  publisher        String
  description      String   @db.Text
  subjects         String[]
  gradeRange       String
  philosophyScores Json     // {montessori: 0.8, waldorf: 0.3, ...}
  prepLevel        String   // open-and-go / light / moderate / heavy
  religiousType    String   // secular / christian / other
  faithDepth       String   // none / light / worldview / fully-integrated
  priceRange       String
  qualityScore     Float
  affiliateUrl     String?
  settingFit       String[] // individual, co-op, micro-school, private-school
  notes            String?  @db.Text
  active           Boolean  @default(true)

  curriculumPicks  CompassCurriculumPick[]

  @@index([active])
}

model CompassCurriculumPick {
  id              String @id @default(uuid())
  compassResultId String
  curriculumId    String
  matchScore      Float
  subject         String

  compassResult CompassResult @relation(fields: [compassResultId], references: [id], onDelete: Cascade)
  curriculum    Curriculum    @relation(fields: [curriculumId], references: [id], onDelete: Cascade)

  @@index([compassResultId])
  @@index([curriculumId])
}
