		<style id="wp-custom-css">
			/*-----------------------------
    PAGE SPECIFIC 
-----------------------------*/
input#choice_2_57_1 {
   
	margin-top: -59px !important;}
.fl-builder-content button:not(.fl-content-ui-button), .fl-builder-content input[type=button], .fl-builder-content input[type=submit], .fl-builder-content .fl-button:is(a, button), .fl-builder-content button:not(.fl-content-ui-button) *, .fl-builder-content input[type=button] *, .fl-builder-content input[type=submit] *, .fl-builder-content .fl-button:is(a, button) *, .fl-builder-content button:visited, .fl-builder-content input[type=button]:visited, .fl-builder-content input[type=submit]:visited, .fl-builder-content a.fl-button:visited, .fl-builder-content button:visited *, .fl-builder-content input[type=button]:visited *, .fl-builder-content input[type=submit]:visited *, .fl-builder-content a.fl-button:visited *, .fl-page .fl-builder-content button:not(.fl-content-ui-button), .fl-page .fl-builder-content input[type=button], .fl-page .fl-builder-content input[type=submit], .fl-page .fl-builder-content .fl-button:is(a, button), .fl-page .fl-builder-content button:not(.fl-content-ui-button) *, .fl-page .fl-builder-content input[type=button] *, .fl-page .fl-builder-content input[type=submit] *, .fl-page .fl-builder-content .fl-button:is(a, button) *, .fl-page .fl-builder-content button:visited, .fl-page .fl-builder-content input[type=button]:visited, .fl-page .fl-builder-content input[type=submit]:visited, .fl-page .fl-builder-content a.fl-button:visited, .fl-page .fl-builder-content button:visited *, .fl-page .fl-builder-content input[type=button]:visited *, .fl-page .fl-builder-content input[type=submit]:visited *, .fl-page .fl-builder-content a.fl-button:visited *{
	color:#000000!important;
}
/* Target main and quick links menus for inline display to prevent link exceeding */
#menu-main>li a,
#menu-footermenu>li a,
#menu-footermenu1>li a {
    display: inline-block;
}

/* Hide legend text on contact form */
p.gform_required_legend {
    display: none;
}

/* Add spacing for list icons in address */
.uabb-info-list-content-wrapper.uabb-info-list-left .uabb-info-list-icon {
    margin-right: 10px;
}

/* To hide outline in menu icon */
.uabb-creative-menu-mobile-toggle:focus {
    outline: none;
}

/* Border styling for new interactive banner */
.uabb-new-ib {
    border-bottom: 10px solid #97C177;
}

/* To show row without overlapping with page content */
.aboverow {
    position: relative;
    z-index: 2;
}

/* To make list as per site layout */
div#tablist ul li::marker {
    font-size: 20px;
    color: #6d3894 !important;
    content: "\f058    ";
    font-family: "Font Awesome 5 Free";
    font-weight: 900;
    line-height: 40px;
}

/* To make list as per site layout */
div#tablist1 ul li::marker {
    font-size: 20px;
    color: #6d3894 !important;
    content: "\f0c1    ";
    font-family: "Font Awesome 5 Free";
    font-weight: 900;
    line-height: 40px;
}

/* To make images size equal */
.team img.wp-post-image {
    height: auto !important;
    max-height: 380px;
    object-fit: contain !important;
    background-color: #97C177;
    padding: 20px;
}

/* To style post items */
.team .fl-post-text {
    padding: 20px;
    text-align: center;
}

/* To align testimonials dots */
.bx-wrapper .bx-pager {
    text-align: left;
}

/* Events buttons styling */
button.tribe-common-c-btn.tribe-events-c-search__button,
.tribe-common .tribe-common-c-btn-border,
.fl-builder-content .footform .pp-subscribe-form a.fl-button,
input#gform_submit_button_1,
button#tribe-tickets__tickets-submit,
button.tribe-common-c-btn.tribe-common-c-btn--small.tribe-tickets__attendee-tickets-submit.tribe-tickets__attendee-tickets-footer-checkout-button.tribe-validation-submit {
    padding: 12px 25px !important;
    border: none;
    font-size: 18px !important;
    font-weight: 400 !important;
    text-transform: capitalize !important;
    border: 1px solid #6D3894 !important;
    background-color: #6D3894 !important;
    color: #fff !important;
    margin-right: 7px;
    border-radius: 0px !important;
}

/* Button width adjustment for subscribe dropdown */
.single-tribe_events .tribe-events-c-subscribe-dropdown__button {
    width: 300px;
}

/* Hover styling for events buttons */
button.tribe-common-c-btn.tribe-events-c-search__button:hover,
.tribe-common .tribe-common-c-btn-border:hover,
.fl-builder-content .footform .pp-subscribe-form a.fl-button:hover,
input#gform_submit_button_1:hover,
button#tribe-tickets__tickets-submit:hover,
button.tribe-common-c-btn.tribe-common-c-btn--small.tribe-tickets__attendee-tickets-submit.tribe-tickets__attendee-tickets-footer-checkout-button.tribe-validation-submit:hover {
    border: 1px solid #6D3894 !important;
    background-color: #00000000 !important;
    color: #6D3894 !important;
}

/* To add border line for event CTA */
.tribe-events button.tribe-events-c-top-bar__datepicker-button:hover {
    border: 1px solid #6D3894 !important;
}

/* Styling for subscribe dropdown button text */
button.tribe-events-c-subscribe-dropdown__button-text {
    outline: none !important;
    text-transform: capitalize;
    background-color: transparent !important;
    border: 1px solid transparent !important;
}

/* Font styling for breakpoints */
.tribe-common--breakpoint-medium.tribe-common .tribe-common-b2,
.tribe-events-content p,
.tribe-events-calendar-month__calendar-event-details {
    font-size: 18px !important;
}

/* To adjust search icon style */
.tribe-events .tribe-events-c-events-bar__search-button-icon-svg path {
    fill: #000000;
}

/* To adjust the spacing of the search icon in the events */
button.tribe-events-c-events-bar__search-button {
    margin-top: 7px;
}

/* For styling for events */
span.tribe-events-c-top-bar__datepicker-desktop.tribe-common-a11y-hidden {
    color: #1E1E1E !important;
    font-size: 20px !important;
    padding: 10px;
    outline: none !important;
    border: none;
}

/* For form feild width */
.gform_wrapper.gravity-theme .ginput_container_date input {
    width: 100% !important;
}

/* For form feild width */
.gform_wrapper.gravity-theme .ginput_container_time {
    flex-basis: min-content;
    max-width: 80px !important;
    min-width: 80px !important;
}

/*-----------------------------
    LARGE SCREENS ONLY
-----------------------------*/
@media screen and (min-width: 769px) {
    /* Prevent single word break on titles */
    .desktop-break {
        display: block;
    }
/* 	.uabb-new-ib-content uabb-text-editor uabb-simplify p{
		margin-top: -10px
	} */

    /* To style interactive banner */
    .uabb-ib-effect-style2 .uabb-new-ib-content {
        position: relative;
        padding-top: 60px;
    }
	
.uabb-ib-effect-style2 .uabb-new-ib-title {
    position: absolute;
	top: 25%;}

    /* For styling list items */
    div#numberlist .pp-heading-content .pp-sub-heading,
    .numberlist .pp-heading-content .pp-sub-heading {
        column-count: 2 !important;
    }
}

/*-----------------------------
    TABLET SCREENS AND SMALLER
-----------------------------*/
@media screen and (max-width: 768px) {
	input#choice_2_57_1 {
    margin-top: -118px !important;
}
	.img-100-mob img{
		width: 100%;
	}
	
#img-row > .fl-col-content {
    background-color: rgb(69 69 69 / 0%);
}	
	
    /* Ensure footer navigation links are inline */
    div#hf-menu li a,
    #menu-main-5>li a {
        display: inline-block;
        padding: 5px 0px;
    }

    /* To remove hero overlay */
    .hero-banner > .fl-row-content-wrap:after {
        background-color: rgb(0 0 0 / 0%);
    }

    /* To hide hero slider */
    .fl-bg-slideshow {
        display: none;
    }

    /* To style event */
    span.tribe-events-c-top-bar__datepicker-mobile,
    time.tribe-events-calendar-month__day-date-daynum {
        color: #000 !important;
        font-size: 18px;
    }
}

/* ONLY TAB MODE */
@media screen and (min-width: 481px) and (max-width: 768px) {
    /* To style interactive banner */
    .uabb-ib-effect-style2 .uabb-new-ib-content {
        position: relative;
        padding-top: 125px;
    }
}

/*-------------------------------
    MOBILE SCREENS ONLY
---------------------------------*/
@media screen and (max-width: 480px) {
	
	input#choice_2_57_1 {
   
	margin-top: -259px !important;}
    /* To style interactive banner */
    .uabb-ib-effect-style2 .uabb-new-ib-content {
        position: relative;
        padding-top: 205px;
    }
	.uabb-ib-effect-style2 .uabb-new-ib-title {
    top: 40%;
}
.fl-node-ychkea18ibsl .fl-node-content .uabb-new-ib {
    height: 350px;
}	
.fl-node-zu5gnr32sxyk .pp-image-carousel
 {
        height: 182px !important;
    }
}

	@media screen and (min-width: 481px) and (max-width: 768px) {
    .uabb-ib-effect-style2 .uabb-new-ib-content {
        position: relative;
        padding-top: 240px;
    }
}		</style>
		</head>
