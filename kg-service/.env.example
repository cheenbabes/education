# At least one API key required
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Provider selection: "openai" or "anthropic"
EXTRACTION_PROVIDER=openai
GENERATION_PROVIDER=openai

# Model overrides (defaults shown)
# OPENAI_EXTRACTION_MODEL=gpt-4.1
# OPENAI_GENERATION_MODEL=gpt-4.1-mini
# OPENAI_VALIDATION_MODEL=gpt-4.1-mini
