# Evidence reads these for the Postgres source.
# For local dev against docker-compose:
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DATABASE=eduapp
POSTGRES_USER=eduapp
POSTGRES_PASSWORD=eduapp_dev
POSTGRES_SSL=false

# For Railway production, copy the connection pieces from Railway's DATABASE_URL:
# POSTGRES_HOST=monorail.proxy.rlwy.net
# POSTGRES_PORT=<from url>
# POSTGRES_DATABASE=railway
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=<from url>
# POSTGRES_SSL=true
